## Runtime-only Dockerfile — uses pre-built shadow JAR (skips Gradle build)
FROM docker.io/library/eclipse-temurin:21-jre

WORKDIR /app

COPY eventlens-app/build/libs/eventlens.jar /app/eventlens.jar
COPY eventlens.yaml /app/eventlens.yaml

EXPOSE 9090

ENV EVENTLENS_CONFIG=/app/eventlens.yaml

ENTRYPOINT ["java", "--enable-preview", "-jar", "/app/eventlens.jar"]
