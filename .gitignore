# =============================================================
# EventLens — .gitignore
# =============================================================

# Compiled class files and IDE bin/ directories
**/bin/

# Gradle build outputs
**/build/
**/dist/
**/.gradle/

# JARs (except Gradle wrapper)
**/*.jar
!gradle/wrapper/gradle-wrapper.jar

# Node / frontend
eventlens-ui/node_modules/
eventlens-ui/.vite/
eventlens-ui/.env.development.local

# TypeScript incremental build caches
*.tsbuildinfo

# IDE
.idea/
*.iml
.vscode/
.cursor/
.DS_Store
Thumbs.db
.cursor/

# Runtime logs and debug dumps
logs/
*.log
*.txt

# Local scratchpad plans (not part of the repo)
plans/

# Config with real credentials — commit *.yaml.example instead
eventlens.yaml

# Test runtime
.testcontainers.properties

# Local AI agent rules / dev tooling config
.agents/
.gemini/

#personal files
tests/
versions/
loadtests/
plans/
