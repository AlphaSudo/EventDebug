# EventLens Configuration — Example
# Copy this file to eventlens.yaml and fill in your real values.
# eventlens.yaml is gitignored — never commit real credentials.

server:
  port: 9090

  # Set allowed-origins to restrict CORS in production
  # Use "*" only in development
  allowed-origins:
    - "http://localhost:5173"   # Vite dev server
    - "http://localhost:9090"   # Embedded server

  auth:
    enabled: false
    username: admin
    password: CHANGE_ME   # Replace with a strong password

datasource:
  url: jdbc:postgresql://localhost:5432/your_db_name
  username: your_pg_user
  password: CHANGE_ME   # Replace with your real DB password
  table:                       # Optional: auto-detected if omitted

kafka:                         # Optional section — remove to disable Kafka
  bootstrap-servers: localhost:9092
  topic: your-events-topic

replay:
  default-reducer: generic     # "generic" | classpath
  reducers:
    # BankAccount: com.myapp.reducers.BankAccountReducer

anomaly:
  scan-interval-seconds: 60
  rules:
    - code: NEGATIVE_BALANCE
      condition: "balance < 0"
      severity: HIGH
    - code: LARGE_WITHDRAWAL
      condition: "amount > 10000"
      severity: MEDIUM

ui:
  theme: dark                  # dark | light
