# Default: auto-detect and normalize line endings
* text=auto

# Force LF for files that must run in Linux containers
*.sh text eol=lf
gradlew text eol=lf
*.properties text eol=lf
*.kts text eol=lf
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Keep Windows batch files as CRLF
*.bat text eol=crlf

# Binary files - no line ending conversion
*.jar binary
